{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/c", "destination": "/candidatos.html", "permanent": false },
    { "source": "/c/", "destination": "/candidatos.html", "permanent": false }
  ],
  "rewrites": [
    { "source": "/candidato.html", "destination": "/api/candidato" },
    { "source": "/candidato", "destination": "/api/candidato" },
    { "source": "/c/:id", "destination": "/api/candidato?id=:id" }
  ],
  "functions": {
    "api/candidato.js": {
      "includeFiles": "{candidato-template.html,candidatos-data.js}"
    }
  }
}
